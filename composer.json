{
    "name": "mamun724682/laravel-db-governor",
    "description": "Production-safety database governance layer for Laravel",
    "keywords": ["laravel", "database", "governance", "query-approval", "audit", "security"],
    "license": "MIT",
    "homepage": "https://github.com/mamun724682/laravel-db-governor",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/database": "^10|^11|^12|^13",
        "illuminate/http": "^10|^11|^12|^13",
        "illuminate/pagination": "^10|^11|^12|^13",
        "illuminate/support": "^10|^11|^12|^13",
        "illuminate/view": "^10|^11|^12|^13"
    },
    "require-dev": {
        "orchestra/testbench": "^8|^9|^10|^11",
        "pestphp/pest": "^2|^3|^4",
        "pestphp/pest-plugin-laravel": "^2|^3|^4",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1"
    },
    "autoload": {
        "psr-4": {
            "Mamun724682\\DbGovernor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mamun724682\\DbGovernor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Mamun724682\\DbGovernor\\DbGovernorServiceProvider"]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "lint": "vendor/bin/pint --test",
        "lint:fix": "vendor/bin/pint"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
