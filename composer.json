{
    "name": "mamun724682/laravel-db-governor",
    "description": "Production-safety database governance layer for Laravel",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/database": "^10|^11|^12|^13",
        "illuminate/http": "^10|^11|^12|^13",
        "illuminate/pagination": "^10|^11|^12|^13",
        "illuminate/support": "^10|^11|^12|^13",
        "illuminate/view": "^10|^11|^12|^13"
    },
    "require-dev": {
        "orchestra/testbench": "^8|^9|^10|^11",
        "pestphp/pest": "^2|^3|^4",
        "pestphp/pest-plugin-laravel": "^2|^3|^4",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Mamun724682\\DbGovernor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mamun724682\\DbGovernor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Mamun724682\\DbGovernor\\DbGovernorServiceProvider"]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
